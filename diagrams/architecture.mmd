```mermaid
graph TD
    %% Define nodes with icons using Font Awesome
    classDef aws fill:#FF9900,color:white,stroke:#333,stroke-width:2px
    classDef proxmox fill:#E6522C,color:white,stroke:#333,stroke-width:2px
    classDef client fill:#4285F4,color:white,stroke:#333,stroke-width:2px
    classDef public fill:#34A853,color:white,stroke:#333,stroke-width:2px
    classDef storage fill:#673AB7,color:white,stroke:#333,stroke-width:2px

    %% Clients and Public Internet
    User["👤 User (You)"]:::client
    Public["🌐 Public Users"]:::public
    Internet["🌍 Internet"]:::public
    
    %% AWS Components
    subgraph AWS[🅰️ AWS Cloud]
        EC2["EC2 Instance (t3.micro)
        -------------------
        • Nginx Reverse Proxy
        • WireGuard VPN Server
        • Fail2Ban
        • UFW Firewall"]:::aws
        
        subgraph S3[S3 & DynamoDB]
            S3Bucket["S3 Bucket
            • Terraform State"]
            DynamoDB["DynamoDB Table
            • State Locking"]
        end
    end
    
    %% Proxmox Components
    subgraph Proxmox[🏢 Proxmox VE]
        PVE["Proxmox Node
        ----------------
        • LXC Containers
        • VMs"]:::proxmox
        
        subgraph Services
            PublicApp["Public Apps
            • Web Apps
            • Portals"]
            PrivateApp["Private Services
            • Plex
            • Management"]
        end
    end
    
    %% Network Flows
    %% User to VPN
    User -->|1. WireGuard VPN (UDP 51820)| EC2
    User -->|2. SSH (TCP 22)| EC2
    
    %% Public Traffic
    Public -->|HTTP/HTTPS (80/443)| Internet
    Internet -->|3. Reverse Proxy| EC2
    
    %% VPN to Proxmox
    EC2 <-->|4. Secure VPN Tunnel| PVE
    
    %% Internal Traffic
    EC2 -->|5.a Public Services| PublicApp
    EC2 -->|5.b Private Services| PrivateApp
    
    %% State Management
    EC2 <-->|6. State Sync| S3Bucket
    EC2 <-->|7. Lock State| DynamoDB

    %% Legend
    click User "#" _blank
    click EC2 "#" _blank
    click PVE "#" _blank
    click S3Bucket "#" _blank
    click DynamoDB "#" _blank
    
    %% Styling
    style AWS fill:#f9f9f9,stroke:#FF9900,stroke-width:2px,stroke-dasharray: 5 5
    style Proxmox fill:#f9f9f9,stroke:#E6522C,stroke-width:2px,stroke-dasharray: 5 5
    style Services fill:#f0f0f0,stroke:#666,stroke-width:1px
